        WhatsApp[WhatsApp Adapter]
        DiscordBridge[DiscordChatBridge]
    end

    subgraph McpHandlers
        CheckpointHandler[McpCheckpointToolHandler]
        IngestionHandler[McpIngestionToolHandler]
    end

    subgraph PolymarketBridge
