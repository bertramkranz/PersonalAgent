flowchart TD
    subgraph Interfaces
        CLI[Interactive CLI]
        Headless[Headless Prompt]
        MCP[MCP Server]
        Webhook[Webhook Server]
        Discord[Discord Bot]
    end

    subgraph RuntimeComposition
        RuntimeFactory[BertBotRuntimeFactory]
        RuntimeCore[BertBotRuntime]
        ExternalChatHandler[BertBotExternalChatHandler]
