## BertBot local runtime settings
# Copy this file to .env and provide your local values.

# Select the AI provider adapter used by the runtime.
# Current shipped adapter: openai
BERTBOT_AI_PROVIDER=openai

# Surface a model preference for the active provider adapter.
# The shipped OpenAI adapter still uses its built-in default model.
BERTBOT_AI_MODEL=gpt-4o-mini

# Provider-specific API key for the active adapter.
# Use BERTBOT_AI_API_KEY for the active provider adapter.
BERTBOT_AI_API_KEY=your-api-key-here

# Webhook server bind settings.
BERTBOT_WEBHOOK_HOST=0.0.0.0
BERTBOT_WEBHOOK_PORT=8088
BERTBOT_WEBHOOK_TELEGRAM_PATH=/webhook/telegram
BERTBOT_WEBHOOK_SLACK_PATH=/webhook/slack
BERTBOT_WEBHOOK_WHATSAPP_PATH=/webhook/whatsapp
BERTBOT_WEBHOOK_HEALTH_PATH=/health

# When true, process webhook payloads without persistence writes.
BERTBOT_WEBHOOK_DRY_RUN=false

# Enable provider signature checks for webhook requests.
BERTBOT_WEBHOOK_REQUIRE_SIGNATURES=false

# Trust forwarded IP headers from a known reverse proxy.
BERTBOT_WEBHOOK_TRUST_PROXY_HEADERS=false

# Optional allowlist (comma-separated IPs/CIDRs). Leave blank to allow all.
BERTBOT_WEBHOOK_ALLOWED_IPS=

# Per-client rate limit settings.
BERTBOT_WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=60
BERTBOT_WEBHOOK_RATE_LIMIT_MAX_REQUESTS=120

# Connector toggles.
BERTBOT_TELEGRAM_ENABLED=true
BERTBOT_SLACK_ENABLED=true
BERTBOT_WHATSAPP_ENABLED=true

# Optional normalized source metadata values.
BERTBOT_SLACK_WORKSPACE_ID=
BERTBOT_WHATSAPP_BUSINESS_PHONE_ID=

# Ingestion approval policy.
BERTBOT_INGESTION_REQUIRE_APPROVAL=true

# Provider verification settings (required when BERTBOT_WEBHOOK_REQUIRE_SIGNATURES=true).
BERTBOT_TELEGRAM_SECRET_TOKEN=
BERTBOT_SLACK_SIGNING_SECRET=
BERTBOT_SLACK_MAX_REQUEST_AGE_SECONDS=300
BERTBOT_WHATSAPP_APP_SECRET=
BERTBOT_WHATSAPP_VERIFY_TOKEN=

