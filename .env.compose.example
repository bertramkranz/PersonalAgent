## Docker Compose runtime settings for self-hosted deployment.
# Copy this file to .env.compose and fill in sensitive values.

# Container run mode.
# Supported values: webhook, mcp, headless, interactive
BERTBOT_RUN_MODE=webhook

# Supported adapters: openai, ollama
BERTBOT_AI_PROVIDER=openai
BERTBOT_AI_MODEL=gpt-4o-mini
BERTBOT_AI_API_KEY=your-openai-api-key

# Ollama adapter settings (used when BERTBOT_AI_PROVIDER=ollama).
BERTBOT_OLLAMA_BASE_URL=http://ollama:11434
BERTBOT_OLLAMA_TIMEOUT_SECONDS=120

# Optional workspace root override for MCP workspace tools.
BERTBOT_WORKSPACE_ROOT=

# Persistence backend (compose defaults to PostgreSQL).
# Supported values: file, jdbc, postgres, postgresql
BERTBOT_STATE_STORE=postgres
BERTBOT_STATE_FILE_PATH=state/bertbot-state.json
BERTBOT_MEMORY_EPISODIC_FILE_PATH=state/bertbot-memory.txt
BERTBOT_MEMORY_SEMANTIC_FILE_PATH=state/bertbot-semantic-memory.txt
BERTBOT_PROFILE_FILE_PATH=state/bertbot-profile.json
BERTBOT_INGESTION_CONSENT_FILE_PATH=state/bertbot-ingestion-consent.json
BERTBOT_INGESTION_SOURCE_STATE_FILE_PATH=state/bertbot-ingestion-source-state.json
BERTBOT_RESEARCH_RECOMMENDATIONS_FILE_PATH=state/bertbot-research-recommendations.json
BERTBOT_TRACE_FILE_PATH=logs/bertbot-trace.jsonl
BERTBOT_INTERACTIONS_FILE_PATH=state/bertbot-interactions.mmd
BERTBOT_STATE_JDBC_URL=jdbc:postgresql://postgres:5432/bertbot
BERTBOT_STATE_JDBC_USER=bertbot
BERTBOT_STATE_JDBC_PASSWORD=bertbot
BERTBOT_STATE_JDBC_TABLE=bertbot_state_snapshot
BERTBOT_MEMORY_EPISODIC_JDBC_TABLE=bertbot_memory_episodic_snapshot
BERTBOT_MEMORY_SEMANTIC_JDBC_TABLE=bertbot_memory_semantic_snapshot
BERTBOT_PROFILE_JDBC_TABLE=bertbot_profile_snapshot
BERTBOT_INGESTION_CONSENT_JDBC_TABLE=bertbot_ingestion_consent_snapshot
BERTBOT_INGESTION_SOURCE_STATE_JDBC_TABLE=bertbot_ingestion_source_state_snapshot

# Continuous improvement research runtime overrides.
BERTBOT_RESEARCH_ENABLED=true
BERTBOT_RESEARCH_EVENT_DRIVEN_ENABLED=true
BERTBOT_RESEARCH_PERIODIC_ENABLED=true
BERTBOT_RESEARCH_LLM_ASSISTED_ENABLED=true
BERTBOT_RESEARCH_INCLUDE_EXTERNAL_SIGNALS=true
BERTBOT_RESEARCH_PERIODIC_INTERVAL_SECONDS=21600
BERTBOT_RESEARCH_MIN_INTERVAL_SECONDS=300
BERTBOT_RESEARCH_MAX_RECOMMENDATIONS_PER_CYCLE=8
BERTBOT_RESEARCH_FAILURE_COOLDOWN_SECONDS=900

# Polymarket endpoint overrides.
BERTBOT_POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
BERTBOT_POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
BERTBOT_POLYMARKET_DATA_BASE_URL=https://data-api.polymarket.com

# Optional Google Workspace MCP proxy settings.
BERTBOT_GOOGLE_WORKSPACE_ENABLED=false
BERTBOT_GOOGLE_WORKSPACE_COMMAND=npx
BERTBOT_GOOGLE_WORKSPACE_ARGS=-y,-p,github:gemini-cli-extensions/workspace#v0.0.8,gemini-workspace-server
BERTBOT_GOOGLE_WORKSPACE_TIMEOUT_SECONDS=60
BERTBOT_GOOGLE_WORKSPACE_TOOL_NAME_PREFIX=google_workspace_

# Optional MacroFactor MCP proxy settings.
BERTBOT_MACROFACTOR_ENABLED=false
BERTBOT_MACROFACTOR_COMMAND=npx
BERTBOT_MACROFACTOR_ARGS=-y,sjawhar-macrofactor
BERTBOT_MACROFACTOR_USERNAME=
BERTBOT_MACROFACTOR_PASSWORD=
BERTBOT_MACROFACTOR_TIMEOUT_SECONDS=45
BERTBOT_MACROFACTOR_TOOL_NAME_PREFIX=macrofactor_

# Webhook bind settings (compose defaults are also set in docker-compose.yml).
BERTBOT_WEBHOOK_HOST=0.0.0.0
BERTBOT_WEBHOOK_PORT=8088

# Webhook path and security settings.
BERTBOT_WEBHOOK_TELEGRAM_PATH=/webhook/telegram
BERTBOT_WEBHOOK_SLACK_PATH=/webhook/slack
BERTBOT_WEBHOOK_WHATSAPP_PATH=/webhook/whatsapp
BERTBOT_WEBHOOK_HEALTH_PATH=/health
BERTBOT_WEBHOOK_DRY_RUN=false
BERTBOT_WEBHOOK_REQUIRE_SIGNATURES=false
BERTBOT_WEBHOOK_TRUST_PROXY_HEADERS=false
BERTBOT_WEBHOOK_ALLOWED_IPS=
BERTBOT_WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=60
BERTBOT_WEBHOOK_RATE_LIMIT_MAX_REQUESTS=120

# Connector toggles.
BERTBOT_TELEGRAM_ENABLED=true
BERTBOT_SLACK_ENABLED=true
BERTBOT_WHATSAPP_ENABLED=true
BERTBOT_SLACK_WORKSPACE_ID=
BERTBOT_WHATSAPP_BUSINESS_PHONE_ID=
BERTBOT_INGESTION_REQUIRE_APPROVAL=true

# Provider verification settings.
BERTBOT_TELEGRAM_SECRET_TOKEN=
BERTBOT_SLACK_SIGNING_SECRET=
BERTBOT_SLACK_MAX_REQUEST_AGE_SECONDS=300
BERTBOT_WHATSAPP_APP_SECRET=
BERTBOT_WHATSAPP_VERIFY_TOKEN=

